# Copy this file to ".env" and fill in your key. The .env file is git-ignored.

# football-data.org API token — free: https://www.football-data.org/client/register
# Used for complete club + World Cup fixtures, kickoff times, and live scores.
FOOTBALL_DATA_API_KEY=

# Supabase — free: https://supabase.com (Project Settings → API)
# SUPABASE_URL = the Project URL; SUPABASE_SERVICE_KEY = the service_role key
# (secret; server-side only). Used by `python -m sports_model.main push`.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
